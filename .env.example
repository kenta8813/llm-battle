# JWT Settings (required - use a long random string in production)
JWT_SECRET=your-secret-key-here-change-this-in-production
JWT_EXPIRES_IN=7d

# Database (PostgreSQL - get this from Supabase project settings)
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres

# Server
PORT=3000
NODE_ENV=development

# API Base URL (for MCP server)
API_BASE_URL=http://localhost:3000

# CORS (comma-separated list of allowed origins)
# Default: http://localhost:5173,http://localhost:3000
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Frontend API endpoints (set in .env at src/web/client/)
# VITE_API_BASE=https://yourdomain.com/api
# VITE_WS_URL=https://yourdomain.com

# Log level
LOG_LEVEL=INFO
